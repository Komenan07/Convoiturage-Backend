# 📁 Dossier des dépendances
node_modules/

# 🧪 Fichiers de logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 📂 Dossiers temporaires
tmp/
temp/

# 🧠 Fichiers de configuration système
.DS_Store
Thumbs.db

# 🔐 Fichiers sensibles ou secrets
.env
.env.local
.env.*.locals


# Fichiers de config Twilio
twilio-production-config.txt
twilio-staging-config.txt
*.txt

# 🧪 Résultats de tests ou coverage
coverage/
*.lcov

# 🛠️ Fichiers de build ou de transpilation
dist/
build/

# 📦 Fichiers de package lock (optionnel selon ton workflow)
package-lock.json
yarn.lock
pnpm-lock.yaml
test

# Firebase
config/serviceAccountKey.json

# Docker
docker-compose.override.yml
.env.staging
.env.production

# Backups
backups/*.gz

# Uploads (ne pas versionner les fichiers uploadés)
uploads/*
!uploads/documents/.gitkeep
!uploads/photos/.gitkeep
!uploads/profils/.gitkeep
!uploads/selfies/.gitkeep
!uploads/users/.gitkeep
!uploads/temp/.gitkeep
!uploads/vehicules/.gitkeep

